# Secrets — real values live in GitHub Actions Secrets / a local .env, never in git
.env
.env.local
.env.*.local
config/settings.toml
# web/config.js is intentionally COMMITTED: GitHub Pages serves the static page
# from the repo, and it holds only the public anon key (gated by RLS). The
# service_role key lives in GitHub Actions Secrets and never appears in web/.

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# Node (static page tooling, if any)
node_modules/

# No on-disk app state — all state lives in the hosted DB (Design B §1)
data/
