# Local-testing template. Copy to .env (git-ignored) and fill in.
# In production these are GitHub Actions Secrets, read from the environment.
# NEVER commit real values. Names below match the repo's GitHub Actions Secrets.

# The Odds API key
ODDSAPIKEY=

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASEURL=

# Supabase service_role key (workflow-side; full DB access — server only)
SUPABASEKEY=

# --- Not yet wired (added as those build steps land) -------------------------
# Supabase anon key (static page, RLS-scoped)
# SUPABASE_ANON_KEY=
# Transactional-email API key (alert + morning summary)
# EMAIL_API_KEY=
# Static selection-page access token
# PAGE_ACCESS_TOKEN=

# Local test override: where the historical backtest data lives (see tests/)
# BACKTEST_ROOT=C:\Users\pdube\odds-backtest-verification
